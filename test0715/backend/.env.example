# DATABASE_URL=postgresql+psycopg://postgres:ENCODED_PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require

# Local file uploads (relative to cwd when running uvicorn from backend/)
UPLOAD_DIR=uploads

# AI service
AI_SERVICE_URL=http://localhost:8001
AI_TIMEOUT_S=30

# ASR: volcengine | aliyun (aliyun not implemented)
ASR_PROVIDER=volcengine
# Volcano (legacy console): APP ID -> X-Api-App-Key, Access Token -> X-Api-Access-Key
VOLC_ASR_APP_ID=6462728315
VOLC_ASR_ACCESS_TOKEN=kpyNiA4HajjLJnytkr_mkBCFOGPx8HGR

# Fast ASR resource id (console must enable volc.bigasr.auc_turbo or change to your id)
VOLC_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
# false = 直连火山，不读系统/环境代理（Windows 错误代理易 ConnectError）；需公司代理时改为 true
VOLC_HTTP_TRUST_ENV=false

# Enable persisting debug ASR results to transcripts table
ASR_DEBUG_PERSIST=true
